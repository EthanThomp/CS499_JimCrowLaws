# Environment variables for database configuration
# Copy this file to .env and update with your actual values

# Database Configuration
POSTGRES_DB=jimcrow_laws
POSTGRES_USER=jimcrow_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# PgAdmin Configuration (Web-based database admin tool)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_this_password
PGADMIN_PORT=8080

# Application Configuration
DATABASE_URL=postgresql://jimcrow_user:your_secure_password_here@localhost:5432/jimcrow_laws