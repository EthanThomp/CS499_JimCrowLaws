# -------------------------------------------------------
# OCR Component  (ocr/jim_crow_ocr.py)
#   pip install llama-parse llama-index python-dotenv
# -------------------------------------------------------
LLAMA_API_KEY=your_key_here

# -------------------------------------------------------
# Document Processing Component  (doc_processing/processor.py)
# -------------------------------------------------------

# Choose one: anthropic | openai | ollama | openai_like
LLM_PROVIDER=anthropic

# Model name for the chosen provider. Leave blank to use
# the provider's default (shown in comments below).
LLM_MODEL=

# Anthropic  (default model: claude-haiku-4-5-20251001)
#   pip install llama-index-llms-anthropic
ANTHROPIC_API_KEY=your_key_here

# OpenAI  (default model: gpt-4o-mini)
#   pip install llama-index-llms-openai
OPENAI_API_KEY=your_key_here

# Ollama — local/open-source models  (default model: llama3)
#   pip install llama-index-llms-ollama
#   Requires Ollama running locally: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible APIs  (Groq, Together AI, LM Studio, OpenRouter, etc.)
#   pip install llama-index-llms-openai-like
#   LLM_MODEL is required for this provider.
#
#   Examples:
#     Groq:        OPENAI_LIKE_BASE_URL=https://api.groq.com/openai/v1
#                  LLM_MODEL=llama-3.1-8b-instant
#     Together AI: OPENAI_LIKE_BASE_URL=https://api.together.xyz/v1
#                  LLM_MODEL=meta-llama/Llama-3-8b-chat-hf
#     LM Studio:   OPENAI_LIKE_BASE_URL=http://localhost:1234/v1
#                  OPENAI_LIKE_API_KEY=lm-studio
#                  LLM_MODEL=<model loaded in LM Studio>
#     OpenRouter:  OPENAI_LIKE_BASE_URL=https://openrouter.ai/api/v1
#                  LLM_MODEL=<model slug, e.g. anthropic/claude-3-haiku>
OPENAI_LIKE_API_KEY=your_key_here
OPENAI_LIKE_BASE_URL=https://api.groq.com/openai/v1
